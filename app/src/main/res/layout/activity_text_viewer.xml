<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cypher_paper">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/cypher_ink"
        app:titleTextColor="@color/cypher_paper"
        app:navigationIcon="@drawable/ic_prev"/>

    <!-- Inline search bar, hidden until search icon tapped -->
    <LinearLayout
        android:id="@+id/layout_search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/cypher_ink_light"
        android:padding="8dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/edit_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/search_hint"
            android:textColorHint="@color/cypher_text_secondary"
            android:textColor="@color/white"
            android:background="@null"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>

        <TextView
            android:id="@+id/text_match_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cypher_paper"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"/>

        <ImageButton
            android:id="@+id/button_search_prev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_prev"
            android:contentDescription="@string/action_prev"/>

        <ImageButton
            android:id="@+id/button_search_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_next"
            android:contentDescription="@string/action_next"/>

        <ImageButton
            android:id="@+id/button_search_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:contentDescription="@android:string/cancel"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/cypher_text_primary"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:fontFamily="monospace"/>
    </ScrollView>

    <!-- Bottom bar: zoom (font size) + page navigation across sibling files -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/cypher_ink"
        android:padding="8dp">

        <ImageButton
            android:id="@+id/button_zoom_out"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_zoom_out"
            android:contentDescription="@string/action_zoom_out"/>

        <ImageButton
            android:id="@+id/button_zoom_in"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_zoom_in"
            android:contentDescription="@string/action_zoom_in"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/button_prev_file"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_prev"
            android:contentDescription="@string/action_prev"/>

        <TextView
            android:id="@+id/text_page_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cypher_paper"
            android:textSize="13sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <ImageButton
            android:id="@+id/button_next_file"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_next"
            android:contentDescription="@string/action_next"/>
    </LinearLayout>
</LinearLayout>
